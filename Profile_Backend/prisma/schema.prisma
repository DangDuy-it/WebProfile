// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Profile {
  Id              Int      @id @default(autoincrement())
  Badge           String?  @db.NVarChar(100)
  Title           String?  @db.NVarChar(100)
  Description     String?  @db.NVarChar(Max)
  AvtDarkImage    String?  @db.NVarChar(500)
  AvtLightImage   String?  @db.NVarChar(500)
  Intro           String?  @db.NVarChar(Max)
  Body            String?  @db.NVarChar(Max)
  CreatedAt       DateTime @default(now())
  UpdatedAt       DateTime @default(now()) @updatedAt

  AboutHighlights AboutHighlight[]
  Skills          Skill[]
  Projects        Project[]
  ContactInfos    ContactInfo[]
}

model AboutHighlight {
  Id          Int      @id @default(autoincrement())
  ProfileId   Int
  University  String?  @db.NVarChar(200)
  Major       String?  @db.NVarChar(200)
  Goal        String?  @db.NVarChar(Max)
  Focus       String?  @db.NVarChar(200)
  Fact        String?  @db.NVarChar(200)
  CreatedAt   DateTime @default(now())

  Profile     Profile  @relation(fields: [ProfileId], references: [Id], onDelete: Cascade)

  @@map("About_highlight")
}

model Skill {
  Id          Int      @id @default(autoincrement())
  ProfileId   Int
  Name        String   @db.NVarChar(100)
  Category    String?  @db.NVarChar(50)
  Level       Int      @default(5)
  Description String?  @db.NVarChar(500)
  IsVisible   Boolean  @default(true)
  OrderIndex  Int      @default(0)
  CreatedAt   DateTime @default(now())

  Profile     Profile  @relation(fields: [ProfileId], references: [Id], onDelete: Cascade)
}

model Project {
  Id           Int      @id @default(autoincrement())
  ProfileId    Int
  Title        String   @db.NVarChar(200)
  Description  String?  @db.NVarChar(Max)
  TechStack    String?  @db.NVarChar(500)
  LinkDemo     String?  @db.NVarChar(500)
  LinkGithub   String?  @db.NVarChar(500)
  ImageUrl     String?  @db.NVarChar(500)
  IsFeatured   Boolean  @default(false)
  IsVisible    Boolean  @default(true)
  OrderIndex   Int      @default(0)
  CreatedAt    DateTime @default(now())
  UpdatedAt    DateTime @default(now()) @updatedAt

  Profile      Profile  @relation(fields: [ProfileId], references: [Id], onDelete: Cascade)
}

model ContactInfo {
  Id         Int      @id @default(autoincrement())
  ProfileId  Int
  Type       String   @db.NVarChar(50)
  Name       String?  @db.NVarChar(50)
  Value      String   @db.NVarChar(500)
  Icon       String?  @db.NVarChar(100)
  IsVisible  Boolean  @default(true)
  OrderIndex Int      @default(0)
  CreatedAt  DateTime @default(now())

  Profile    Profile  @relation(fields: [ProfileId], references: [Id], onDelete: Cascade)
}