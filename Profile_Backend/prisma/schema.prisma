generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Profile {
  Id             Int              @id @default(autoincrement())
  Email          String?          @unique @db.NVarChar(255)
  Name           String?          @db.NVarChar(255)
  Badge          String?          @db.NVarChar(100)
  Title          String?          @db.NVarChar(100)
  Description    String?          @db.NVarChar(Max)
  AvtDarkImage   String?          @db.NVarChar(500)
  AudioUrl       String?          @db.NVarChar(255)
  Intro          String?          @db.NVarChar(Max)
  Body           String?          @db.NVarChar(Max)
  CreatedAt      DateTime         @default(now())
  UpdatedAt      DateTime         @default(now())
  
  AboutHighlight AboutHighlight[]
  ContactInfo    ContactInfo[]
  Project        Project[]
  Skill          Skill[]
  Timeline       Timeline[]

  @@map("Profile")
}

model ContactInfo {
  Id         Int      @id @default(autoincrement())
  ProfileId  Int
  Type       String   @db.NVarChar(50)
  Name       String?  @db.NVarChar(50)
  Value      String   @db.NVarChar(500)
  Icon       String?  @db.NVarChar(100)
  Category   String?  @db.NVarChar(255)
  IsVisible  Boolean  @default(true)
  OrderIndex Int      @default(0)
  CreatedAt  DateTime @default(now())
  Profile    Profile  @relation(fields: [ProfileId], references: [Id], onDelete: Cascade)

  @@map("ContactInfo")
}

model Skill {
  Id          Int      @id @default(autoincrement())
  ProfileId   Int
  Name        String   @db.NVarChar(100)
  Category    String?  @db.NVarChar(50)
  Description String?  @db.NVarChar(500)
  Icon        String?  @db.NVarChar(255)
  IsVisible   Boolean  @default(true)
  OrderIndex  Int      @default(0)
  CreatedAt   DateTime @default(now())
  Profile     Profile  @relation(fields: [ProfileId], references: [Id], onDelete: Cascade)

  @@map("Skill")
}

model Project {
  Id          Int      @id @default(autoincrement())
  ProfileId   Int
  Title       String   @db.NVarChar(200)
  Category    String   @db.NVarChar(100)
  Description String?  @db.NVarChar(Max)
  TechStack   String?  @db.NVarChar(500)
  LinkDemo    String?  @db.NVarChar(500)
  LinkGithub  String?  @db.NVarChar(500)
  ImageUrl    String?  @db.NVarChar(500)
  IsFeatured  Boolean  @default(false)
  IsVisible   Boolean  @default(true)
  OrderIndex  Int      @default(0)
  CreatedAt   DateTime @default(now())
  Profile     Profile  @relation(fields: [ProfileId], references: [Id], onDelete: Cascade)

  @@map("Project")
}

model Timeline {
  Id          Int      @id @default(autoincrement())
  ProfileId   Int
  Type        String   @db.NVarChar(50) 
  Title       String   @db.NVarChar(200)
  Duration    String   @db.NVarChar(100)
  Description String?  @db.NVarChar(Max)
  OrderIndex  Int      @default(0)
  Profile     Profile  @relation(fields: [ProfileId], references: [Id], onDelete: Cascade)

  @@map("Timeline")
}


model AboutHighlight {
  Id         Int      @id @default(autoincrement())
  ProfileId  Int
  Name       String?  @db.NVarChar(100)
  Description String? @db.NVarChar(100)
  Icon        String? @db.NVarChar(100)
  OrderIndex  Int      @default(0)
  Profile    Profile  @relation(fields: [ProfileId], references: [Id], onDelete: Cascade)

  @@map("AboutHighlight")
}